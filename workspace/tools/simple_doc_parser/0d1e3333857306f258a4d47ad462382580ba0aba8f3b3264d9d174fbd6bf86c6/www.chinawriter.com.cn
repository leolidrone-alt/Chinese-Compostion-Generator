<script>
	$(function(){
	var numselect;
	var cishu=0;
	$('.btnSelect').on("click",function(){
		var index= $(".btnSelect").index(this);		
		$(".ulDiv").removeClass("ulShow");  
  		$(this).siblings(".ulDiv").toggleClass("ulShow");
		if(numselect == index){
			$(this).siblings(".ulDiv").removeClass("ulShow");
			cishu++;
			if(cishu%2==0 && cishu > 0){
				$(this).siblings(".ulDiv").toggleClass("ulShow");
			}
			else{
				$(this).siblings(".ulDiv").removeClass("ulShow");
			}
		}
		else{
			numselect=index;
			cishu=0;
		}		
	});  
	$(".ulDiv ul li").on("click",function(){ 
  	$(".ulDiv").removeClass("ulShow");  
	}); 
})
</script>
